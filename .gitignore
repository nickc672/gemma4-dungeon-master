# =====================================================================
# .gitignore
# ---------------------------------------------------------------------
# Keep the repo lean: source, scenarios, world data (actors.json,
# locations.json, items.json, story.json) and configs ARE tracked.
# Caches, virtualenvs, IDE noise, and per-run artifacts are not.
# =====================================================================


# ---------- Python bytecode and caches ----------
__pycache__/
*.py[cod]
*$py.class
*.so

# Type-checker and linter caches
.mypy_cache/
.pyright/
.pytype/
.ruff_cache/
.pytest_cache/
.tox/
.nox/


# ---------- Virtual environments ----------
# (Match common names; the trailing slash means "directory" only,
# so a stray file literally named `venv` would still be tracked.)
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/


# ---------- Packaging and distribution ----------
build/
dist/
*.egg
*.egg-info/
.installed.cfg
pip-wheel-metadata/
*.whl


# ---------- Test and coverage artifacts ----------
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.cache/
nosetests.xml


# ---------- IDE and editor cruft ----------
.vscode/
.idea/
*.iml
*.swp
*.swo
*~
.project
.pydevproject
.settings/


# ---------- OS junk ----------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/


# ---------- Secrets and local config ----------
# The .env *file* (env vars, API keys). Not to be confused with the
# .env/ directory pattern above, which is a virtualenv folder.
.env
.env.local
.env.*.local
*.pem
*.key
secrets/


# ---------- Logs ----------
*.log
logs/


# =====================================================================
# Project-specific runtime artifacts
# =====================================================================

# Benchmark output: per-model JSON result files and HTML reports.
# These are generated by `python3 -m benchmark.runner` and
# `python3 -m benchmark.report`, and are reproducible from source,
# so they don't belong in the repo.
benchmark/output/
output/

# Session checkpoints: written by cli.py when --state-root is set.
# Default state root is `state/`, also commonly `sessions/`.
state/
sessions/
*.checkpoint
*.snapshot

# Local Ollama scratch (in case anyone symlinks the model store
# into the repo for inspection; the real store lives in ~/.ollama).
.ollama/

# Scratch files Claude/Cursor/Copilot tend to leave around
.claude/
.cursor/
scratch/
tmp/